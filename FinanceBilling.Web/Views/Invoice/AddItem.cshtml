@model FinanceBilling.Web.ViewModels.AddItemViewModel
@{
    ViewData["Title"] = "Add Item";
}

<h2 class="mb-4">Add Item to Invoice</h2>

<div class="row">
    <div class="col-md-5">
        <form asp-action="AddItem" method="post">
            <input type="hidden" asp-for="InvoiceId" />

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="UnitPrice" class="form-label"></label>
                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="UnitPrice" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Add Item</button>
            <a asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}